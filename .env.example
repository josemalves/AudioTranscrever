# Random secret to sign session cookies (gera com: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Admin inicial — criado no primeiro arranque se não existir nenhum admin na BD
ADMIN_USERNAME=admin
ADMIN_EMAIL=jose.alves@expertmode.pt
ADMIN_PASSWORD=change-me-strong-password

# Modelo Whisper (alternativas: medium, small, base, tiny)
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=pt

# Token do HuggingFace para diarização (pyannote)
# Cria em: https://huggingface.co/settings/tokens (tipo Read)
# Aceita os termos em:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notificações por email (opcional — se vazio, simplesmente não envia)
# Exemplo OVH: ssl0.ovh.net:465 com SSL
# Exemplo Gmail: smtp.gmail.com:587 com starttls (precisa de App Password)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=ssl

# URL pública usada nos links dos emails
APP_URL=http://localhost:8080
